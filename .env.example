# ── Rugby Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values
# [REQUIRED] must be set before running the app
# [OPTIONAL] can be left empty to disable the feature
# ─────────────────────────────────────────────────────────────────────────────

# ── Database [REQUIRED] ──────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For serverless deploys (e.g. Vercel), point this at a connection pooler
# (PgBouncer / Supabase pooler / Neon) to avoid exhausting Postgres connections.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rugby
# Max connections per pool instance. Keep low on serverless (1–5).
DATABASE_POOL_MAX=5

# ── Better Auth [REQUIRED] ───────────────────────────────────────────────────
# Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin of the app (used for trusted origins + secure-cookie detection).
BASE_URL=http://localhost:3000

# ── Frontend [REQUIRED] ──────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Resend [OPTIONAL] ────────────────────────────────────────────────────────
# Required to send verification emails. Get your API key at https://resend.com
# Leave empty to disable email sending
RESEND_API_KEY=
# Use a verified domain sender, e.g. noreply@yourdomain.com
RESEND_FROM_EMAIL=

# ── Sentry [OPTIONAL] ────────────────────────────────────────────────────────
# Leave empty to disable error tracking
NEXT_PUBLIC_SENTRY_DSN=
# Required for source map uploads in CI/CD (Sentry > Settings > Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
